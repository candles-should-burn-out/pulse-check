# Copy this file to .env for local Docker Compose, and to a protected
# environment file on production hosts. Do not commit real secrets.

COMPOSE_PROJECT_NAME=pulse-check

# Public URLs used by browsers.
APP_PUBLIC_URL=http://localhost:3000
KEYCLOAK_PUBLIC_URL=http://localhost:8081
FRONTEND_PORT=3000
KEYCLOAK_PORT=8081

# Keycloak bootstrap admin for the master realm.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Keycloak database.
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me

# Pulse Check product database.
PULSE_CHECK_DB_NAME=pulse_check
PULSE_CHECK_DB_USER=pulse_check
PULSE_CHECK_DB_PASSWORD=change-me

# Pulse Check OIDC settings.
OIDC_ISSUER=http://localhost:8081/realms/pulse-check
OIDC_JWKS_URL=http://keycloak:8080/realms/pulse-check/protocol/openid-connect/certs
OIDC_AUDIENCE=pulse-check-api
OIDC_REQUIRED_ROLE=
STATUS_SET_MAX_STATUSES=50

# Frontend build-time settings.
VITE_API_BASE_URL=/api
VITE_APP_PUBLIC_URL=http://localhost:3000
VITE_KEYCLOAK_URL=http://localhost:8081
VITE_KEYCLOAK_REALM=pulse-check
VITE_KEYCLOAK_CLIENT_ID=pulse-check-frontend

# Optional tracing.
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
VITE_OTEL_SERVICE_NAME=pulse-check-frontend
OTEL_SERVICE_NAME=pulse-check-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
